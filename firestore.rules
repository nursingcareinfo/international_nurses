rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // GLOBAL HELPERS & VALIDATION FUNCTIONS (Top-level)
    // ==========================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == "nursingcareinfo21@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Auth tokens NEVER contain custom claims.
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function getApplication(appId) {
      return get(/databases/$(database)/documents/applications/$(appId));
    }

    function applicationExists(appId) {
      return exists(/databases/$(database)/documents/applications/$(appId));
    }

    function isValidApplication(data) {
      return data.get('fullName', '') is string && data.get('fullName', '').size() > 0 && data.get('fullName', '').size() <= 150 &&
             data.get('email', '') is string && data.get('email', '').size() > 0 && data.get('email', '').size() <= 150 &&
             data.get('phone', '') is string && data.get('phone', '').size() > 0 && data.get('phone', '').size() <= 50 &&
             data.get('licenseNumber', '') is string && data.get('licenseNumber', '').size() > 0 && data.get('licenseNumber', '').size() <= 50 &&
             data.get('userId', '') is string && data.get('userId', '').size() <= 128 &&
             data.get('createdAt', '') is string && data.get('createdAt', '').size() <= 50;
    }

    function isValidUserProfile(data) {
      return data.get('applicationId', '') is string && data.get('applicationId', '').size() <= 128 &&
             data.get('fullName', '') is string && data.get('fullName', '').size() > 0 && data.get('fullName', '').size() <= 150 &&
             (data.get('email', '') is string && data.get('email', '').size() <= 150) &&
             (data.get('phone', '') is string && data.get('phone', '').size() <= 50) &&
             (data.get('education', '') is string && data.get('education', '').size() <= 2000) &&
             (data.get('experience', '') is string && data.get('experience', '').size() <= 2000) &&
             (data.get('skills', '') is string && data.get('skills', '').size() <= 2000);
    }

    function isValidPncLicenseData(data) {
      return data.get('applicationId', '') is string && data.get('applicationId', '').size() <= 128 &&
             data.get('licenseNumber', '') is string && data.get('licenseNumber', '').size() > 0 && data.get('licenseNumber', '').size() <= 100 &&
             (data.get('councilName', '') is string && data.get('councilName', '').size() <= 100) &&
             (data.get('category', '') is string && data.get('category', '').size() <= 100) &&
             (data.get('verificationStatus', '') is string && data.get('verificationStatus', '').size() <= 50) &&
             (data.get('graduationYear', 1950) is int && data.get('graduationYear', 1950) >= 1950 && data.get('graduationYear', 1950) <= 2100);
    }

    // ==========================================
    // 0. GLOBAL SAFETY NET (Must be first match block)
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // 1. APPLICATIONS COLLECTION
    // ==========================================
    match /applications/{applicationId} {
      allow get: if isAdmin() || (resource != null && resource.data.get('userId', '') != '' && isOwner(resource.data.get('userId', '')));
      
      allow list: if isAdmin() || (isSignedIn() && resource.data.get('userId', '') == request.auth.uid);
      
      allow create: if isValidId(applicationId) && 
                    isValidApplication(incoming()) && 
                    (incoming().get('userId', '') == '' || isOwner(incoming().get('userId', '')));
                    
      allow update: if isValidId(applicationId) && 
                    isValidApplication(incoming()) && (
                      isAdmin() || (
                        isOwner(existing().get('userId', '')) &&
                        incoming().get('userId', '') == existing().get('userId', '') &&
                        incoming().get('createdAt', '') == existing().get('createdAt', '')
                      )
                    );
                    
      allow delete: if isAdmin();
    }

    // ==========================================
    // 2. USER PROFILES COLLECTION
    // ==========================================
    match /user_profiles/{profileId} {
      allow get: if isAdmin() || (resource != null && applicationExists(resource.data.get('applicationId', '')) && 
                     getApplication(resource.data.get('applicationId', '')).data.get('userId', '') == request.auth.uid);
                     
      allow list: if isAdmin();
      
      allow create: if isValidId(profileId) && 
                    isValidUserProfile(incoming()) && 
                    applicationExists(incoming().get('applicationId', '')) && (
                      isAdmin() || (
                        getApplication(incoming().get('applicationId', '')).data.get('userId', '') == '' || 
                        isOwner(getApplication(incoming().get('applicationId', '')).data.get('userId', ''))
                      )
                    );
                    
      allow update: if isValidId(profileId) && 
                    isValidUserProfile(incoming()) && (
                      isAdmin() || (
                        incoming().get('applicationId', '') == existing().get('applicationId', '') &&
                        applicationExists(existing().get('applicationId', '')) && (
                          isOwner(getApplication(existing().get('applicationId', '')).data.get('userId', ''))
                        )
                      )
                    );
                    
      allow delete: if isAdmin();
    }

    // ==========================================
    // 3. PNC LICENSE DATA COLLECTION
    // ==========================================
    match /pnc_license_data/{licenseId} {
      allow get: if isAdmin() || (resource != null && applicationExists(resource.data.get('applicationId', '')) && 
                     getApplication(resource.data.get('applicationId', '')).data.get('userId', '') == request.auth.uid);
                     
      allow list: if isAdmin();
      
      allow create: if isValidId(licenseId) && 
                    isValidPncLicenseData(incoming()) && 
                    applicationExists(incoming().get('applicationId', '')) && (
                      isAdmin() || (
                        getApplication(incoming().get('applicationId', '')).data.get('userId', '') == '' || 
                        isOwner(getApplication(incoming().get('applicationId', '')).data.get('userId', ''))
                      )
                    );
                    
      allow update: if isValidId(licenseId) && 
                    isValidPncLicenseData(incoming()) && (
                      isAdmin() || (
                        incoming().get('applicationId', '') == existing().get('applicationId', '') &&
                        applicationExists(existing().get('applicationId', '')) && (
                          isOwner(getApplication(existing().get('applicationId', '')).data.get('userId', ''))
                        )
                      )
                    );
                    
      allow delete: if isAdmin();
    }
  }
}
